# DeepSeek API 配置
DEEPSEEK_API_KEY=your_api_key_here

# 外部API配置（速度轴、伤害计算）
SPEED_AXIS_API_URL=http://localhost:8080/api/speed-axis
DAMAGE_CALC_API_URL=http://localhost:8080/api/damage-calc

# 数据库配置（生产环境使用PostgreSQL，本地调试使用SQLite）
DATABASE_URL=sqlite:///./local_demo.db

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
