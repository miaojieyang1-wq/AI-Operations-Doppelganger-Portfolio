DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 可选：演示模式。设为 1 时读取本地预设结果，不实时调用 API。
AI_OPS_DEMO_MODE=0

# 可选：覆盖用户数据目录。默认使用系统用户级数据目录。
AI_OPS_DATA_DIR=

# 可选：管理后台密码哈希。建议通过首次配置生成，不建议手写明文密码。
AI_OPS_ADMIN_PASSWORD_HASH=

# 可选：FastAPI Bearer Token。配置后业务接口必须携带 Authorization: Bearer <token>。
AI_OPS_API_TOKEN=

# 可选：FastAPI 是否允许显式持久化。默认 0，即使请求传 persist=true 也不入库。
AI_OPS_API_PERSISTENCE=0

# 可选：本地报告保存总开关。默认 1，但只有用户点击保存按钮才会落盘。
AI_OPS_ENABLE_LOCAL_SAVE=1

# 可选：保存 Markdown 报告时是否生成 JSON 附加文件。
AI_OPS_SAVE_JSON_SIDECAR=1

# 可选：数据库连接。默认位于用户数据目录，不建议写到安装目录。
DATABASE_URL=
